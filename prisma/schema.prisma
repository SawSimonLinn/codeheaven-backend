generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Receipt {
  id            String   @id @default(uuid())
  createdAt     DateTime @default(now())
  receiptNumber String   @unique
  clientName    String
  clientEmail   String
  companyName   String?
  issueDate     String
  dueDate       String?
  items         String   // JSON stringified ReceiptItem[]
  subtotal      Float
  tax           Float
  discount      Float
  total         Float
  notes         String   @default("")
  status        String   @default("draft")

  @@map("receipts")
}

model Counter {
  id    String @id @default(uuid())
  name  String @unique
  count Int    @default(0)

  @@map("counters")
}

model AuditLog {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  event      String
  email      String
  path       String
  ip         String
  userAgent  String
  deviceType String
  browser    String
  os         String
  city       String
  region     String
  country    String

  @@map("audit_logs")
}

model AdminUser {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  name         String

  @@map("admin_users")
}
