# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://chs_user:chs_pass@localhost:5432/codeheaven?schema=public"

# ── Auth ──────────────────────────────────────────────────────────────────────
# 32+ character random string – generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret-value"

# Admin credentials (used by seed script to create the admin user)
ADMIN_EMAIL="admin@codeheaven.studio"
ADMIN_PASSWORD="change-me-before-deploying"
ADMIN_NAME="Code Heaven Admin"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-smtp-user"
SMTP_PASS="your-smtp-password"
SMTP_FROM="Code Heaven Studio <noreply@codeheaven.studio>"
